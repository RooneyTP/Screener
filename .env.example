# Screener / Telegram Bot - Environment Template
# Salin file ini menjadi .env lalu isi nilai aslinya.
# JANGAN commit .env ke git (sudah dilindungi .gitignore).

# --- Telegram Bot (wajib untuk telegram_bot.py) ---
# Token dari @BotFather, Chat ID dari @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord Notifications (opsional) ---
# Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=

# --- Yahoo Finance (opsional - free tier tidak perlu key) ---
API_KEY_YFINANCE=

# --- Redis cache (opsional) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Email Alerts (opsional) ---
EMAIL_ALERT_TO=
EMAIL_ALERT_FROM=
SMTP_HOST=
SMTP_PORT=587
